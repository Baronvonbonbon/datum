# DATUM Publisher Relay Bot — Environment Configuration
#
# Copy this to .env and fill in your values.

# Your publisher wallet private key (hex, with 0x prefix)
# This key signs EIP-712 attestations and pays gas for relay submissions.
# KEEP THIS SECRET — never commit it to version control.
PUBLISHER_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC endpoint for pallet-revive chain
RPC_URL=https://eth-rpc-testnet.polkadot.io/

# HTTP server port (default: 3400)
PORT=3400

# Poll interval in ms — how often to submit queued batches (default: 300000 = 5 min)
POLL_INTERVAL_MS=300000

# Contract addresses (Paseo TestNet defaults shown)
RELAY_ADDRESS=0x0c2F453B48f4eC13f4c6f4d5708765A2f57Ca65B
SETTLEMENT_ADDRESS=0x6dCbe782CFa9255adc94fdb821E6A7bc092fccc3
CAMPAIGNS_ADDRESS=0x1337cD3be712079688EbbD2DA2455F981522ab1d
PAUSE_REGISTRY_ADDRESS=0xFa0e0D4cb23a9616f780Cb0Ad4055E9b5fE6d1bD
