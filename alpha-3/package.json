{
  "name": "datum-alpha-3",
  "version": "0.3.0",
  "description": "DATUM Alpha-3 — satellite extraction, targeting redesign, bot mitigation",
  "scripts": {
    "compile": "npx hardhat compile",
    "compile:polkavm": "npx hardhat compile --network polkadotHub",
    "test": "npx hardhat test",
    "test:coverage": "npx hardhat coverage",
    "deploy:local": "npx hardhat run scripts/deploy.ts --network hardhat",
    "deploy:substrate": "npx hardhat run scripts/deploy.ts --network substrate",
    "deploy:polkavm": "npx hardhat run scripts/deploy.ts --network polkadotHub",
    "deploy:testnet": "npx hardhat run scripts/deploy.ts --network polkadotTestnet",
    "setup:testnet": "npx hardhat run scripts/setup-testnet.ts --network polkadotTestnet"
  },
  "devDependencies": {
    "@noble/hashes": "^2.0.1",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@parity/hardhat-polkadot": "^0.2.7",
    "@parity/hardhat-polkadot-node": "^0.2.5",
    "@parity/hardhat-polkadot-resolc": "^0.2.3",
    "@parity/resolc": "^1.0.0",
    "circomlib": "^2.0.5",
    "hardhat": "^2.22.0",
    "snarkjs": "^0.7.6",
    "solc": "0.8.24",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  }
}
